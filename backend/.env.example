MONGODB_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=gamegold
JWT_SECRET=your-super-secret-jwt-key-change-this

# LLM Provider — swap model string to change provider
# Dev (free):  groq/llama-3.3-70b-versatile  → get key at console.groq.com
# Prod:        claude-sonnet-4-6              → get key at console.anthropic.com
LLM_MODEL=groq/llama-3.3-70b-versatile
LLM_API_KEY=gsk_...

# Sprite image generation (Phase 3) — optional, get a token at replicate.com
# Scripts and dialogue trees work without it; only sprites need this.
REPLICATE_API_TOKEN=

DEBUG=false
